<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AgentSpace · Engineer Interview</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#0f1117;
  --surface:#16191f;
  --surface-2:#1d2129;
  --surface-3:#242a33;
  --border:#2a303a;
  --border-soft:#222830;
  --text:#e8eaf0;
  --text-2:#9aa0ac;
  --text-3:#5a6070;
  --accent:#4f8ef7;
  --accent-dim:#1e3560;
  --accent-glow:rgba(79,142,247,0.15);
  --green:#3ecf8e;
  --green-dim:#0e3025;
  --amber:#f5a623;
  --r:10px;
  --r-sm:6px;
}

html,body{height:100%;overflow:hidden}

body{
  font-family:'Geist',sans-serif;
  background:var(--bg);
  color:var(--text);
  display:flex;
  flex-direction:column;
}

/* ── ONBOARDING ─────────────────────────────────── */
#onboard{
  position:fixed;inset:0;
  background:rgba(10,12,16,0.85);
  backdrop-filter:blur(8px);
  display:flex;align-items:center;justify-content:center;
  z-index:999;
}
.ob-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:16px;
  padding:44px 48px;
  width:440px;
  box-shadow:0 32px 80px rgba(0,0,0,0.5);
  animation:fadeUp .35s cubic-bezier(.22,.68,0,1.2);
}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

.ob-wordmark{
  display:flex;align-items:center;gap:10px;
  margin-bottom:32px;
}
.ob-icon{
  width:34px;height:34px;background:var(--accent);
  border-radius:8px;display:flex;align-items:center;justify-content:center;
  font-size:16px;color:white;font-weight:600;letter-spacing:-.5px;
  font-family:'Instrument Serif',serif;
  flex-shrink:0;
}
.ob-brand-name{font-family:'Instrument Serif',serif;font-size:18px;color:var(--text)}
.ob-brand-tag{font-size:12px;color:var(--text-3);margin-left:auto;letter-spacing:.04em;text-transform:uppercase}

.ob-card h1{
  font-family:'Instrument Serif',serif;
  font-size:28px;font-weight:400;
  color:var(--text);
  line-height:1.2;
  margin-bottom:8px;
}
.ob-card h1 em{font-style:italic;color:var(--accent)}
.ob-card p{font-size:14px;color:var(--text-2);line-height:1.65;margin-bottom:30px;font-weight:300}

.ob-role-badge{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--accent-dim);border:1px solid rgba(79,142,247,.3);
  border-radius:20px;padding:5px 12px;
  font-size:13px;color:var(--accent);font-weight:500;
  margin-bottom:24px;
}
.ob-role-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--accent)}

.ob-field{margin-bottom:20px}
.ob-field label{display:block;font-size:12px;font-weight:500;color:var(--text-2);letter-spacing:.04em;text-transform:uppercase;margin-bottom:8px}
.ob-field input{
  width:100%;background:var(--surface-2);
  border:1px solid var(--border);border-radius:var(--r-sm);
  padding:12px 14px;font-family:'Geist',sans-serif;
  font-size:15px;color:var(--text);outline:none;
  transition:border-color .2s,box-shadow .2s;
}
.ob-field input::placeholder{color:var(--text-3)}
.ob-field input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow)}

.ob-btn{
  width:100%;padding:13px;
  background:var(--accent);color:white;border:none;
  border-radius:var(--r-sm);font-family:'Geist',sans-serif;
  font-size:15px;font-weight:500;cursor:pointer;
  transition:opacity .15s,transform .1s;
  margin-top:4px;
  letter-spacing:-.01em;
}
.ob-btn:hover{opacity:.92}
.ob-btn:active{transform:scale(.98)}

/* ── APP SHELL ──────────────────────────────────── */
#app{display:flex;flex-direction:column;height:100%;opacity:0;transition:opacity .4s}
#app.ready{opacity:1}

/* header */
.topbar{
  height:56px;
  border-bottom:1px solid var(--border-soft);
  display:flex;align-items:center;
  padding:0 24px;gap:16px;
  background:var(--surface);
  flex-shrink:0;
}
.topbar-brand{display:flex;align-items:center;gap:9px}
.topbar-icon{
  width:28px;height:28px;background:var(--accent);
  border-radius:6px;display:flex;align-items:center;justify-content:center;
  font-family:'Instrument Serif',serif;font-size:14px;color:white;font-weight:600;
}
.topbar-name{font-family:'Instrument Serif',serif;font-size:16px;color:var(--text)}
.topbar-sep{width:1px;height:18px;background:var(--border);margin:0 4px}
.topbar-session{font-size:13px;color:var(--text-3);font-weight:300}

.topbar-spacer{flex:1}

.track-chips{display:flex;gap:6px}
.chip{
  font-size:11.5px;padding:4px 10px;border-radius:20px;
  background:var(--surface-2);border:1px solid var(--border);
  color:var(--text-3);font-weight:400;transition:all .25s;
  white-space:nowrap;
}
.chip.active{background:var(--accent-dim);border-color:rgba(79,142,247,.4);color:var(--accent)}
.chip.done{background:var(--green-dim);border-color:rgba(62,207,142,.25);color:var(--green)}

.progress-wrap{display:flex;align-items:center;gap:10px;margin-left:12px}
.progress-bar{width:100px;height:3px;background:var(--surface-3);border-radius:2px;overflow:hidden}
.progress-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .6s ease}
.progress-num{font-size:12px;color:var(--text-3);white-space:nowrap}

/* ── BODY ───────────────────────────────────────── */
.body{display:flex;flex:1;min-height:0}

/* sidebar */
.sidebar{
  width:232px;flex-shrink:0;
  border-right:1px solid var(--border-soft);
  background:var(--surface);
  display:flex;flex-direction:column;
  overflow:hidden;
}
.sb-section{padding:20px 16px 0}
.sb-label{font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3);margin-bottom:10px;padding:0 4px}
.profile-block{
  background:var(--surface-2);border:1px solid var(--border);
  border-radius:var(--r);padding:14px;margin-bottom:20px;
}
.profile-avatar{
  width:40px;height:40px;border-radius:50%;
  background:linear-gradient(135deg,var(--accent-dim),var(--accent));
  display:flex;align-items:center;justify-content:center;
  font-size:16px;font-weight:600;color:white;
  margin-bottom:10px;letter-spacing:-.5px;
}
.profile-name{font-size:14px;font-weight:500;color:var(--text);margin-bottom:2px}
.profile-role{font-size:12px;color:var(--accent);font-weight:400}
.profile-stats{
  display:flex;gap:0;margin-top:10px;padding-top:10px;
  border-top:1px solid var(--border);
}
.stat{flex:1;text-align:center}
.stat-n{font-size:18px;font-weight:600;color:var(--text);font-family:'Instrument Serif',serif}
.stat-l{font-size:10.5px;color:var(--text-3);margin-top:1px}

.tracks-list{display:flex;flex-direction:column;gap:2px;padding:0 4px}
.track-item{
  display:flex;align-items:center;gap:10px;
  padding:8px 10px;border-radius:var(--r-sm);
  font-size:13px;color:var(--text-3);
  transition:all .2s;cursor:default;
  border:1px solid transparent;
}
.track-item.active{background:var(--surface-3);border-color:var(--border);color:var(--text)}
.track-item.done{color:var(--green);opacity:.7}
.track-dot{
  width:6px;height:6px;border-radius:50%;
  background:var(--text-3);flex-shrink:0;transition:background .2s;
}
.track-item.active .track-dot{background:var(--accent)}
.track-item.done .track-dot{background:var(--green)}
.track-num{margin-left:auto;font-size:11px;color:var(--text-3);font-weight:400}
.track-item.done .track-num{color:var(--green)}

.sidebar-footer{margin-top:auto;padding:16px;border-top:1px solid var(--border-soft)}
.sf-info{font-size:12px;color:var(--text-3);line-height:1.5}
.sf-dot{width:7px;height:7px;border-radius:50%;background:var(--green);display:inline-block;margin-right:6px;box-shadow:0 0 6px var(--green)}

/* ── CHAT ───────────────────────────────────────── */
.chat-area{flex:1;display:flex;flex-direction:column;min-width:0}
.messages{
  flex:1;overflow-y:auto;
  padding:28px 32px;
  display:flex;flex-direction:column;
  gap:0;
  scroll-behavior:smooth;
}
.messages::-webkit-scrollbar{width:4px}
.messages::-webkit-scrollbar-track{background:transparent}
.messages::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

/* message rows */
.msg-row{display:flex;gap:12px;margin-bottom:24px;animation:msgIn .25s ease}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.msg-row.user{flex-direction:row-reverse}

.msg-avatar{
  width:30px;height:30px;border-radius:50%;
  flex-shrink:0;margin-top:2px;
  display:flex;align-items:center;justify-content:center;
  font-size:12px;font-weight:600;letter-spacing:-.3px;
}
.msg-row.agent .msg-avatar{background:var(--accent);color:white}
.msg-row.user .msg-avatar{background:var(--surface-3);border:1px solid var(--border);color:var(--text-2)}

.msg-body{max-width:68%}
.msg-row.user .msg-body{align-items:flex-end;display:flex;flex-direction:column}
.msg-name{font-size:11.5px;color:var(--text-3);margin-bottom:5px;font-weight:400}
.msg-row.user .msg-name{text-align:right}

.bubble{
  display:inline-block;
  padding:13px 17px;
  border-radius:14px;
  font-size:14.5px;line-height:1.65;
  font-weight:300;
}
.msg-row.agent .bubble{
  background:var(--surface-2);
  border:1px solid var(--border);
  border-bottom-left-radius:4px;
  color:var(--text);
}
.msg-row.user .bubble{
  background:var(--accent);
  border-bottom-right-radius:4px;
  color:white;
  font-weight:400;
}

/* typing */
.typing-bubble{background:var(--surface-2);border:1px solid var(--border);border-radius:14px;border-bottom-left-radius:4px;padding:14px 18px;display:inline-flex;gap:5px;align-items:center}
.td{width:6px;height:6px;border-radius:50%;background:var(--accent);opacity:.5;animation:td 1.2s ease infinite}
.td:nth-child(2){animation-delay:.2s}
.td:nth-child(3){animation-delay:.4s}
@keyframes td{0%,80%,100%{transform:translateY(0);opacity:.4}40%{transform:translateY(-5px);opacity:1}}

/* push deeper pill */
.push-pill{
  align-self:flex-start;margin-left:42px;margin-top:-18px;margin-bottom:16px;
  display:inline-flex;align-items:center;gap:6px;
  background:rgba(245,166,35,.08);border:1px solid rgba(245,166,35,.2);
  border-radius:20px;padding:4px 10px;font-size:11.5px;color:var(--amber);
  animation:msgIn .25s ease;opacity:0;
}
.push-pill.show{opacity:1}

/* ── INPUT ──────────────────────────────────────── */
.input-area{
  border-top:1px solid var(--border-soft);
  padding:14px 24px 18px;
  background:var(--surface);
  display:flex;flex-direction:column;gap:10px;
}
.input-row{display:flex;gap:10px;align-items:flex-end}
.input-box{
  flex:1;background:var(--surface-2);border:1px solid var(--border);
  border-radius:var(--r);padding:11px 14px;
  font-family:'Geist',sans-serif;font-size:14.5px;color:var(--text);
  resize:none;outline:none;min-height:44px;max-height:130px;
  line-height:1.55;transition:border-color .2s,box-shadow .2s;
  font-weight:300;
}
.input-box::placeholder{color:var(--text-3)}
.input-box:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow)}
.input-box:disabled{opacity:.4;cursor:not-allowed}

.send-btn{
  width:44px;height:44px;flex-shrink:0;
  background:var(--accent);border:none;border-radius:var(--r);
  cursor:pointer;color:white;font-size:18px;
  display:flex;align-items:center;justify-content:center;
  transition:opacity .15s,transform .1s;
}
.send-btn:hover{opacity:.88}
.send-btn:active{transform:scale(.94)}
.send-btn:disabled{background:var(--surface-3);cursor:not-allowed;opacity:1}
.send-icon{display:block;line-height:1}

.input-hint{font-size:11.5px;color:var(--text-3);padding:0 2px}
.input-hint kbd{
  background:var(--surface-3);border:1px solid var(--border);
  border-radius:3px;padding:1px 5px;font-size:11px;
  font-family:inherit;color:var(--text-3);
}

/* ── SUMMARY ────────────────────────────────────── */
.summary-wrap{
  display:none;padding:28px 32px;overflow-y:auto;
  flex:1;flex-direction:column;gap:20px;
}
.summary-wrap.show{display:flex}
.sum-header{margin-bottom:4px}
.sum-header h2{font-family:'Instrument Serif',serif;font-size:28px;font-weight:400;color:var(--text);margin-bottom:6px}
.sum-header p{font-size:14px;color:var(--text-2);font-weight:300}
.sum-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:4px}
.sum-card{
  background:var(--surface-2);border:1px solid var(--border);
  border-radius:var(--r);padding:18px;
}
.sum-card h4{font-size:11px;font-weight:600;letter-spacing:.07em;text-transform:uppercase;color:var(--accent);margin-bottom:8px}
.sum-card p{font-size:13.5px;color:var(--text-2);line-height:1.65;font-weight:300}
.sum-actions{display:flex;gap:10px;margin-top:4px}
.sum-btn{
  padding:10px 20px;border:none;border-radius:var(--r-sm);
  font-family:'Geist',sans-serif;font-size:14px;font-weight:500;
  cursor:pointer;transition:opacity .15s;
}
.sum-btn.primary{background:var(--accent);color:white}
.sum-btn.secondary{background:var(--surface-2);color:var(--text-2);border:1px solid var(--border)}
.sum-btn:hover{opacity:.82}
</style>
</head>
<body>

<!-- ONBOARDING -->
<div id="onboard">
  <div class="ob-card">
    <div class="ob-wordmark">
      <div class="ob-icon">A</div>
      <span class="ob-brand-name">AgentSpace</span>
      <span class="ob-brand-tag">Interview</span>
    </div>
    <h1>Let's capture <em>you</em>,<br/>not just your résumé.</h1>
    <p>This session builds a deep model of how you think, communicate, and work. Your answers train an AI agent that represents you — so take your time and be specific.</p>
    <div class="ob-role-badge">Software Engineer</div>
    <div class="ob-field">
      <label>Your full name</label>
      <input id="obName" type="text" placeholder="e.g. Alex Rivera" autocomplete="off"/>
    </div>
    <button class="ob-btn" onclick="beginSession()">Start My Interview →</button>
  </div>
</div>

<!-- APP -->
<div id="app">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-brand">
      <div class="topbar-icon">A</div>
      <span class="topbar-name">AgentSpace</span>
    </div>
    <div class="topbar-sep"></div>
    <span class="topbar-session" id="sessionLabel">Software Engineer Interview</span>
    <div class="topbar-spacer"></div>
    <div class="track-chips" id="topChips"></div>
    <div class="progress-wrap">
      <div class="progress-bar"><div class="progress-fill" id="progFill" style="width:0%"></div></div>
      <span class="progress-num" id="progNum">0 / 50+</span>
    </div>
  </div>

  <div class="body">

    <!-- SIDEBAR -->
    <div class="sidebar">
      <div class="sb-section">
        <div class="sb-label">Interviewee</div>
        <div class="profile-block">
          <div class="profile-avatar" id="sbAvatar">—</div>
          <div class="profile-name" id="sbName">—</div>
          <div class="profile-role">Software Engineer</div>
          <div class="profile-stats">
            <div class="stat">
              <div class="stat-n" id="sbQCount">0</div>
              <div class="stat-l">Questions</div>
            </div>
            <div class="stat">
              <div class="stat-n" id="sbTrackNum">1</div>
              <div class="stat-l">of 7 tracks</div>
            </div>
          </div>
        </div>
      </div>
      <div class="sb-section" style="flex:1;overflow-y:auto;padding-bottom:8px">
        <div class="sb-label">Interview Tracks</div>
        <div class="tracks-list" id="tracksList"></div>
      </div>
      <div class="sidebar-footer">
        <div class="sf-info"><span class="sf-dot"></span>Session in progress</div>
      </div>
    </div>

    <!-- CHAT -->
    <div class="chat-area" id="chatArea">
      <div class="messages" id="messages"></div>
      <div class="input-area">
        <div class="input-row">
          <textarea class="input-box" id="inputBox" placeholder="Type your answer…" rows="1"
            onkeydown="handleKey(event)" oninput="autoGrow(this)"></textarea>
          <button class="send-btn" id="sendBtn" onclick="submit()">
            <span class="send-icon">↑</span>
          </button>
        </div>
        <div class="input-hint"><kbd>Enter</kbd> to send &nbsp;·&nbsp; <kbd>Shift + Enter</kbd> for new line</div>
      </div>
      <!-- summary injected after chat -->
      <div class="summary-wrap" id="summaryWrap">
        <div class="sum-header">
          <h2>Interview Complete</h2>
          <p id="sumSubtitle">Here's what we've captured.</p>
        </div>
        <div class="sum-grid" id="sumGrid"></div>
        <div class="sum-actions">
          <button class="sum-btn primary" onclick="exportTranscript()">Export Transcript</button>
          <button class="sum-btn secondary" onclick="exportJSON()">Export JSON</button>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
// ── CONFIG ────────────────────────────────────────
const PROFESSION = 'Software Engineer';

const TRACKS = [
  { id:'origin',        label:'Origin & Background',    target:8  },
  { id:'personality',   label:'Personality & Values',   target:7  },
  { id:'craft',         label:'Engineering Craft',       target:8  },
  { id:'collaboration', label:'Collaboration & Teams',   target:7  },
  { id:'scenarios',     label:'Tough Scenarios',         target:10 },
  { id:'philosophy',    label:'Philosophy & Opinions',   target:6  },
  { id:'growth',        label:'Growth & Reflection',     target:6  },
];

// ── STATE ─────────────────────────────────────────
const S = {
  name: '',
  messages: [],    // {role,content,ts}
  qCount: 0,
  currentTrack: 0,
  done: false,
  busy: false,
};

// ── INIT ──────────────────────────────────────────
function beginSession() {
  const n = document.getElementById('obName').value.trim();
  if (!n) { document.getElementById('obName').focus(); return; }
  S.name = n;
  document.getElementById('onboard').style.display = 'none';
  document.getElementById('app').classList.add('ready');
  // populate UI
  document.getElementById('sessionLabel').textContent = `${n} · ${PROFESSION}`;
  document.getElementById('sbName').textContent = n;
  document.getElementById('sbAvatar').textContent = initials(n);
  buildTrackList();
  buildTopChips();
  setTrack(0);
  openingMessage();
}

function initials(name) {
  return name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
}

function buildTrackList() {
  const el = document.getElementById('tracksList');
  el.innerHTML = TRACKS.map((t,i) => `
    <div class="track-item" id="tr-${t.id}">
      <div class="track-dot"></div>
      <span>${t.label}</span>
      <span class="track-num">${t.target}q</span>
    </div>`).join('');
}

function buildTopChips() {
  const el = document.getElementById('topChips');
  el.innerHTML = TRACKS.map(t =>
    `<div class="chip" id="chip-${t.id}">${t.label.split(' ')[0]}</div>`
  ).join('');
}

function setTrack(idx) {
  if (idx >= TRACKS.length) return;
  // mark prev done
  for(let i=0;i<idx;i++){
    document.getElementById(`tr-${TRACKS[i].id}`)?.classList.replace('active','done') ||
    document.getElementById(`tr-${TRACKS[i].id}`)?.classList.add('done');
    document.getElementById(`chip-${TRACKS[i].id}`)?.classList.replace('active','done') ||
    document.getElementById(`chip-${TRACKS[i].id}`)?.classList.add('done');
  }
  const id = TRACKS[idx].id;
  const tr = document.getElementById(`tr-${id}`);
  if(tr){ tr.classList.remove('done'); tr.classList.add('active'); }
  const ch = document.getElementById(`chip-${id}`);
  if(ch){ ch.classList.remove('done'); ch.classList.add('active'); }
  S.currentTrack = idx;
  document.getElementById('sbTrackNum').textContent = idx+1;
}

// ── SYSTEM PROMPT ─────────────────────────────────
function systemPrompt() {
  return `You are a specialist interviewer for AgentSpace — a platform that creates AI agents that faithfully replicate real professionals.

Your mission: conduct a deeply thorough interview of ${S.name}, a Software Engineer. Extract enough to train an AI that thinks, communicates, and reacts like them.

TRACKS (work through all 7, ~50 questions total):

1. Origin & Background (~8 questions)
   How they got into software, their education/self-learning path, early influences, what hooked them, pivotal career moments.

2. Personality & Values (~7 questions)
   Core values, how they'd describe themselves vs. how colleagues would, their working style, what frustrates them, what energizes them.

3. Engineering Craft (~8 questions)
   How they approach a new codebase, their debugging mindset, opinions on code quality, architecture instincts, how they balance speed vs. correctness, tech stack preferences and why.

4. Collaboration & Teams (~7 questions)
   How they work in teams, approach code reviews, handle disagreements with teammates, mentor juniors, interact with PMs/designers, async vs. sync preferences.

5. Tough Scenarios (~10 questions) — BE VERY SPECIFIC TO SOFTWARE ENGINEERING:
   - What do they do when they're completely stuck on a bug for hours?
   - How do they handle pressure to ship code they think isn't ready?
   - How do they deal with a teammate who consistently writes poor code?
   - What do they do when requirements change mid-sprint?
   - How do they respond when their technical decision gets overruled?
   - How do they manage technical debt they've inherited?
   - How do they handle a production incident where they're not sure of the root cause?
   Make each scenario feel vivid and concrete. Ask for specific past examples.

6. Philosophy & Opinions (~6 questions)
   Controversial takes on software engineering, opinions others might disagree with, views on AI and coding tools, what they think the industry gets wrong, what makes a great vs. merely good engineer.

7. Growth & Reflection (~6 questions)
   Biggest technical failure and what they learned, how they stay current, what skill they wish they'd developed sooner, what they'd tell their early-career self.

BEHAVIOR RULES:
- Ask exactly ONE question per message. Never bundle questions.
- Keep your setup/acknowledgment to 1 sentence — not effusive, just natural.
- If an answer is vague, too brief, or generic, PUSH DEEPER before moving on. Ask for a concrete example, a specific project, or what was going through their mind. One well-placed follow-up beats moving on too fast.
- Transitions between tracks should feel organic — brief signal, then the new question.
- Tone: curious, focused, intelligent — like a senior colleague who genuinely wants to understand.
- Do NOT compliment every answer. Only acknowledge when something is genuinely interesting.

ENDING:
After 50+ meaningful exchanges (questions + follow-ups), wind down naturally. Then output exactly:
INTERVIEW_COMPLETE
<SUMMARY>
{
  "origin": "2–3 sentence synthesis",
  "personality": "2–3 sentence synthesis",
  "craft": "2–3 sentence synthesis",
  "collaboration": "2–3 sentence synthesis",
  "scenarios": "2–3 sentence synthesis",
  "philosophy": "2–3 sentence synthesis",
  "growth": "2–3 sentence synthesis"
}
</SUMMARY>`;
}

// ── OPENING ───────────────────────────────────────
function openingMessage() {
  const msg = `Hey ${S.name} — good to have you here. This session is going to cover a lot of ground: where you came from, how you work, how you handle the messy situations that don't have clean answers, and what you actually believe about software engineering.

The more honest and specific you are, the better the model we'll build from this. There are no right answers.

To start — **how did you first get into programming?** Was there a specific moment, a project, a person? What was the hook?`;
  appendAgent(msg);
}

// ── MESSAGING ─────────────────────────────────────
function appendAgent(content) {
  const ts = clock();
  S.messages.push({role:'assistant', content, ts});
  S.qCount++;
  renderMsg({role:'assistant', content, ts});
  updateProgress();
}

function renderMsg({role, content, ts}) {
  const div = document.createElement('div');
  div.className = `msg-row ${role === 'assistant' ? 'agent' : 'user'}`;
  const av = role === 'assistant' ? 'AI' : initials(S.name);
  const nm = role === 'assistant' ? 'AgentSpace Interviewer' : S.name;
  div.innerHTML = `
    <div class="msg-avatar">${av}</div>
    <div class="msg-body">
      <div class="msg-name">${nm} · ${ts}</div>
      <div class="bubble">${fmt(content)}</div>
    </div>`;
  document.getElementById('messages').appendChild(div);
  scroll();
}

function fmt(t) {
  return t
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/\n\n/g,'</p><p>')
    .replace(/\n/g,'<br/>')
    .replace(/^(.)/,'<p>$1').replace(/(.)$/,'$1</p>');
}

function showTyping() {
  const d = document.createElement('div');
  d.id = 'typingRow'; d.className = 'msg-row agent';
  d.innerHTML = `<div class="msg-avatar">AI</div><div class="msg-body"><div class="msg-name">AgentSpace Interviewer</div><div class="typing-bubble"><div class="td"></div><div class="td"></div><div class="td"></div></div></div>`;
  document.getElementById('messages').appendChild(d);
  scroll();
}

function hideTyping() {
  document.getElementById('typingRow')?.remove();
}

function scroll() {
  const m = document.getElementById('messages');
  m.scrollTop = m.scrollHeight;
}

function clock() {
  return new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
}

// ── SEND ──────────────────────────────────────────
async function submit() {
  const box = document.getElementById('inputBox');
  const text = box.value.trim();
  if (!text || S.busy || S.done) return;
  box.value = ''; box.style.height = 'auto';

  const ts = clock();
  S.messages.push({role:'user', content:text, ts});
  renderMsg({role:'user', content:text, ts});

  S.busy = true;
  document.getElementById('sendBtn').disabled = true;
  showTyping();

  try {
    const apiMsgs = S.messages.map(m => ({
      role: m.role === 'assistant' ? 'assistant' : 'user',
      content: m.content
    }));

    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt(),
        messages: apiMsgs,
      })
    });

    const data = await res.json();
    hideTyping();
    const raw = (data.content||[]).map(b=>b.text||'').join('') || 'Something went wrong — please try again.';

    if (raw.includes('INTERVIEW_COMPLETE')) {
      S.done = true;
      const before = raw.split('INTERVIEW_COMPLETE')[0].trim();
      if (before) appendAgent(before);
      const sm = raw.match(/<SUMMARY>([\s\S]*?)<\/SUMMARY>/);
      if (sm) {
        try { showSummary(JSON.parse(sm[1].trim())); } catch(e) { console.warn(e); }
      }
      document.getElementById('inputBox').disabled = true;
      document.getElementById('sendBtn').disabled = true;
      // mark all done
      TRACKS.forEach(t => {
        document.getElementById(`tr-${t.id}`)?.classList.add('done');
        document.getElementById(`chip-${t.id}`)?.classList.replace('active','done');
      });
      document.getElementById('progFill').style.width = '100%';
      document.getElementById('progNum').textContent = 'Complete ✓';
    } else {
      detectTrack(raw);
      appendAgent(raw);
    }

  } catch(e) {
    hideTyping();
    appendAgent('I lost the connection for a moment — please resend your last answer.');
    console.error(e);
  }

  S.busy = false;
  if (!S.done) document.getElementById('sendBtn').disabled = false;
}

// ── TRACK DETECTION ───────────────────────────────
const TRACK_SIGNALS = {
  personality:   ['value','personality','describe yourself','frustrat','energi','working style','colleagues would say'],
  craft:         ['codebase','debug','architecture','code quality','stack','refactor','engineering approach','design decision'],
  collaboration: ['team','code review','junior','colleague','pm','designer','feedback','async','sync','mentor'],
  scenarios:     ['stuck','production','incident','pressure','ship','disagree','technical debt','mid-sprint','overruled','requirements changed'],
  philosophy:    ['believe','opinion','think the industry','controversial','ai tool','copilot','what makes a great','wrong about'],
  growth:        ['failure','mistake','learned','stay current','earlier','younger','wish','regret','next'],
};

function detectTrack(text) {
  const lower = text.toLowerCase();
  for (let i = S.currentTrack; i < TRACKS.length; i++) {
    const sigs = TRACK_SIGNALS[TRACKS[i].id];
    if (sigs && sigs.some(s => lower.includes(s))) {
      if (i !== S.currentTrack) setTrack(i);
      return;
    }
  }
}

// ── PROGRESS ──────────────────────────────────────
function updateProgress() {
  const pct = Math.min((S.qCount / 55) * 100, 96);
  document.getElementById('progFill').style.width = pct + '%';
  document.getElementById('progNum').textContent = `${S.qCount} / 50+`;
  document.getElementById('sbQCount').textContent = S.qCount;
}

// ── SUMMARY ───────────────────────────────────────
const TRACK_LABELS = {
  origin:'Origin & Background', personality:'Personality & Values',
  craft:'Engineering Craft', collaboration:'Collaboration & Teams',
  scenarios:'Tough Scenarios', philosophy:'Philosophy & Opinions',
  growth:'Growth & Reflection'
};

function showSummary(obj) {
  document.getElementById('sumSubtitle').textContent =
    `A synthesis of ${S.name}'s profile as a ${PROFESSION}.`;
  const grid = document.getElementById('sumGrid');
  grid.innerHTML = Object.entries(obj).map(([k,v]) =>
    `<div class="sum-card"><h4>${TRACK_LABELS[k]||k}</h4><p>${v}</p></div>`
  ).join('');
  // Swap chat → summary in same panel
  document.getElementById('messages').style.display = 'none';
  document.querySelector('.input-area').style.display = 'none';
  document.getElementById('summaryWrap').classList.add('show');
  document.getElementById('summaryWrap').style.display = 'flex';
}

// ── EXPORT ────────────────────────────────────────
function exportTranscript() {
  const lines = S.messages.map(m =>
    `[${m.ts}] ${m.role==='assistant'?'Interviewer':S.name}:\n${m.content}`
  ).join('\n\n---\n\n');
  const blob = new Blob([`AGENTSPACE INTERVIEW TRANSCRIPT\n${S.name} · ${PROFESSION}\n${'═'.repeat(52)}\n\n`+lines], {type:'text/plain'});
  dl(blob, `${S.name.replace(/\s+/g,'_')}_interview.txt`);
}

function exportJSON() {
  const payload = {
    interviewee: { name: S.name, profession: PROFESSION },
    date: new Date().toISOString(),
    questionCount: S.qCount,
    transcript: S.messages.map(({role,content,ts})=>({role,content,ts})),
  };
  const blob = new Blob([JSON.stringify(payload, null, 2)], {type:'application/json'});
  dl(blob, `${S.name.replace(/\s+/g,'_')}_interview.json`);
}

function dl(blob, name) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob); a.download = name; a.click();
}

// ── UTILS ─────────────────────────────────────────
function handleKey(e) {
  if (e.key==='Enter' && !e.shiftKey){ e.preventDefault(); submit(); }
}
function autoGrow(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 130) + 'px';
}
</script>
